modules = ["nodejs-24", "python-3.11"]

[[artifacts]]
id = "artifacts/api-server"

[[artifacts]]
id = "artifacts/mockup-sandbox"

[deployment]
deploymentTarget = "autoscale"
run = ["streamlit", "run", "civicbridge/app.py", "--server.port", "5000", "--server.address", "0.0.0.0", "--server.headless", "true"]

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "CivicBridge"

[[workflows.workflow]]
name = "CivicBridge"
author = "agent"

[workflows.workflow.metadata]
outputType = "webview"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "echo 'CivicBridge is served by the civicbridge-web artifact on port $PORT. Access it via the preview pane.'"

[agent]
stack = "PNPM_WORKSPACE"
expertMode = true

[postMerge]
path = "scripts/post-merge.sh"
timeoutMs = 20000

[nix]
channel = "stable-25_05"
packages = ["cargo", "freetype", "gumbo", "harfbuzz", "jbig2dec", "libiconv", "libjpeg_turbo", "mupdf", "openjpeg", "rustc", "swig", "xcbuild"]
